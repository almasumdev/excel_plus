# https://dart.dev/guides/libraries/private-files
# Created by `dart pub`
.dart_tool/

# Build artifacts
build/

# Avoid committing pubspec.lock for library packages; see
# https://dart.dev/guides/libraries/private-files#pubspeclock.
pubspec.lock

# Internal docs (analysis, plans — not for distribution)
docs/

# Generated API docs
doc/api/

# Temporary/generated files (benchmarks, test outputs)
.tmp/
*.xlsx
!example/assets/example.xlsx
!test/test_resources/*.xlsx
test/test_output/

# Claude Code local session artifacts
.claude/

# Secrets — NEVER commit credentials. Firebase deploy reads the service-account
# JSON from the FIREBASE_SERVICE_ACCOUNT GitHub Actions secret, not from a file.
*-firebase-adminsdk-*.json
*service-account*.json
*serviceAccount*.json
.firebase/
firebase-debug.log
excel_plus.code-workspace